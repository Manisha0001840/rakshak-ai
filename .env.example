# Google Gemini API key used by the server-side analysis routes.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional model override. The default supports text, image, and audio analysis.
# GEMINI_MODEL=gemini-3.5-flash

# Optional: override the default SQLite location.
# RAKSHAK_DB_PATH=./data/rakshak.sqlite
